stateDiagram-v2
    state "Activitate agricola" as Activitate {
        [*] --> PENDING
        PENDING --> IN_PROGRESS: muncitorul incepe lucrarea
        IN_PROGRESS --> COMPLETED: muncitorul finalizeaza lucrarea
        COMPLETED --> [*]
    }

    state "Cerere de aprovizionare" as Cerere {
        [*] --> REQUEST_PENDING
        REQUEST_PENDING --> APPROVED: managerul aproba
        REQUEST_PENDING --> REJECTED: managerul respinge
        APPROVED --> [*]
        REJECTED --> [*]
    }

    state "Utilaj" as Utilaj {
        [*] --> DISPONIBIL
        DISPONIBIL --> IN_CURSA: lucrare inceputa
        IN_CURSA --> DISPONIBIL: lucrare finalizata
        DISPONIBIL --> IN_SERVICE: interventie service
        IN_SERVICE --> DISPONIBIL: service finalizat
    }
