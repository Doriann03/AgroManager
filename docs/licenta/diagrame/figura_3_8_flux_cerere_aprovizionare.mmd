flowchart TD
    Start([Start]) --> Check["Agronomul verifica stocurile"]
    Check --> Need{"Material suficient?"}
    Need -->|Da| Plan["Planifica lucrarea fara cerere"]
    Plan --> End1([Final])

    Need -->|Nu| Create["Creeaza cerere de aprovizionare"]
    Create --> Pending["Cerere cu status PENDING"]
    Pending --> Notify["Managerul primeste notificare"]
    Notify --> Decision{"Managerul aproba?"}

    Decision -->|Da| Approved["Status APPROVED"]
    Approved --> Stock["Stocul este actualizat"]
    Stock --> NotifyAgr["Agronomul este notificat"]
    NotifyAgr --> End2([Final])

    Decision -->|Nu| Rejected["Status REJECTED"]
    Rejected --> Reason["Cererea ramane in istoric"]
    Reason --> End3([Final])
